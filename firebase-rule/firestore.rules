rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──── V2 Helper Functions ────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isHomesteadMember(homesteadId) {
      return isAuth() && exists(/databases/$(database)/documents/homestead_v2/$(homesteadId)/member_v2/$(request.auth.uid));
    }

    // ──── Production Rules (DO NOT MODIFY) ────

    match /{path=**}/workevent/{wid} {
      allow read, write: if resource.data.userId == request.auth.uid;
    }

    match /feedback/{feedbackid} {
      allow create: if request.auth.uid != null;
    }

    match /user/{userid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/device/{device} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/animal/{animal} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/animal/{animal}/subrecurring/{sid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/animal/{animal}/workevent/{wid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/animal/{animal}/userevent/{wid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/urecurring_template/{urid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/uanimal_type/{uaid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/uanimal_type/{uaid}/ubreed_type/{ubid} {
        allow read, write: if request.auth.uid == userid
    }

    match /user/{userid}/uanimal_type/{uaid}/urecurring_template/{ubid} {
        allow read, write: if request.auth.uid == userid
    }

    match /recurring_template/{id} {
        allow read: if true;
    }

    match /animal_type/{id} {
        allow read: if true;
    }

    match /animal_type/{aid}/breed_type/{bid} {
        allow read: if true;
    }

    match /animal_type/{aid}/recurring_template/{rid} {
        allow read: if true;
    }

    // ──── V2 Rules ────

    match /user_v2/{userId} {
      allow read: if isAuth() && isOwner(userId);
      allow create: if isAuth() && isOwner(userId);
      allow update: if isAuth() && isOwner(userId);
      allow delete: if false;

      match /device_v2/{deviceId} {
        allow read, write: if isAuth() && isOwner(userId);
      }
    }

    match /homestead_v2/{homesteadId} {
      allow read: if isHomesteadMember(homesteadId);
      allow create: if isAuth();
      allow update: if isHomesteadMember(homesteadId);
      allow delete: if false;

      match /member_v2/{memberId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isAuth() && (isHomesteadMember(homesteadId) || request.auth.uid == memberId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /animal_v2/{animalId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /careEvent_v2/{eventId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /healthRecord_v2/{recordId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /breedingRecord_v2/{recordId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /note_v2/{noteId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /weightLog_v2/{logId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /productionLog_v2/{logId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /animalType_v2/{typeId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;

        match /breed_v2/{breedId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }

        match /careTemplate_v2/{templateId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }

        match /eventTemplate_v2/{templateId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }
      }
    }

    match /feedback_v2/{feedbackId} {
      allow create: if isAuth();
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ──── Catch-all Deny (from production) ────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
