rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the user is a member of the homestead (has any role)
    function isHomesteadMember(homesteadId) {
      return isAuth() && exists(/databases/$(database)/documents/homestead_v2/$(homesteadId)/member_v2/$(request.auth.uid));
    }

    // User profile — owner only
    match /user_v2/{userId} {
      allow read: if isAuth() && isOwner(userId);
      allow create: if isAuth() && isOwner(userId);
      allow update: if isAuth() && isOwner(userId);
      allow delete: if false;

      match /device_v2/{deviceId} {
        allow read, write: if isAuth() && isOwner(userId);
      }
    }

    // Homestead — members only
    match /homestead_v2/{homesteadId} {
      allow read: if isHomesteadMember(homesteadId);
      allow create: if isAuth();
      allow update: if isHomesteadMember(homesteadId);
      allow delete: if false;

      // Members — members can read, only homestead members can manage
      match /member_v2/{memberId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      // All farm data — homestead members only
      match /animal_v2/{animalId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /careEvent_v2/{eventId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /healthRecord_v2/{recordId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /breedingRecord_v2/{recordId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /note_v2/{noteId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /weightLog_v2/{logId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      match /productionLog_v2/{logId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;
      }

      // Animal Types — homestead members only (with subcollections)
      match /animalType_v2/{typeId} {
        allow read: if isHomesteadMember(homesteadId);
        allow create: if isHomesteadMember(homesteadId);
        allow update: if isHomesteadMember(homesteadId);
        allow delete: if false;

        match /breed_v2/{breedId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }

        match /careTemplate_v2/{templateId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }

        match /eventTemplate_v2/{templateId} {
          allow read: if isHomesteadMember(homesteadId);
          allow create: if isHomesteadMember(homesteadId);
          allow update: if isHomesteadMember(homesteadId);
          allow delete: if false;
        }
      }
    }

    // Feedback — write-only, read by admin
    match /feedback_v2/{feedbackId} {
      allow create: if isAuth();
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
