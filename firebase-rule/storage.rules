rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // =========================================================
    // PRODUCTION RULES — DO NOT MODIFY
    // These rules are live in production and must not be changed.
    // =========================================================
    match /user/{userid} {
      allow read, write: if request.auth.uid == userid;
    }

    match /user/{userid}/animal/{image} {
      allow read, write: if request.auth.uid == userid;
    }
    // =========================================================
    // END PRODUCTION RULES
    // =========================================================

    // Homestead storage (animal photos, note photos, etc.)
    match /homestead/{homesteadId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
