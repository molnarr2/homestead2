{
  "name": "@homestead/functions",
  "version": "0.0.1",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf lib && tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=lib/index.js --external:firebase-admin --external:firebase-functions",
    "build:watch": "tsc --watch"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
